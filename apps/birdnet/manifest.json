{
  "id": "birdnet",
  "name": "BirdNET",
  "icon": "🐦",
  "description": "Live bird detections from BirdNET-Pi",
  "type": "functional",
  "refresh_interval": 1,
  "loop_delay": 5,
  "category": "data",
  "trigger_interval": 30,
  "trigger_display_seconds": 30,
  "trigger_cooldown": 120,
  "trigger_conditions": [
    {
      "key": "filter",
      "label": "Fire for",
      "type": "toggle",
      "default": "any",
      "options": [
        {"value": "any", "label": "Any detection"},
        {"value": "new_today", "label": "New species today"},
        {"value": "specific", "label": "Specific species"}
      ]
    },
    {
      "key": "species",
      "label": "Species name (partial match)",
      "type": "text",
      "default": "",
      "visible_when": {"filter": "specific"}
    }
  ],
  "settings": [
    {
      "key": "birdnet_host",
      "label": "BirdNET-Pi Host",
      "type": "text",
      "default": "192.168.86.139",
      "global_key": true
    },
    {
      "key": "birdnet_port",
      "label": "Port",
      "type": "number",
      "default": "80",
      "global_key": true
    },
    {
      "key": "display_mode",
      "label": "Display Mode",
      "type": "toggle",
      "default": "latest",
      "global_key": true,
      "options": [
        {"label": "Latest", "value": "latest"},
        {"label": "Last 3", "value": "last_3"},
        {"label": "Leaderboard", "value": "leaderboard"}
      ]
    },
    {
      "key": "min_confidence",
      "label": "Min Confidence %",
      "type": "number",
      "default": "70",
      "min": "50",
      "max": "99",
      "step": "5",
      "stepper": true,
      "global_key": true
    },
    {
      "key": "leaderboard_count",
      "label": "Leaderboard Entries",
      "type": "number",
      "default": "3",
      "min": "1",
      "max": "5",
      "step": "1",
      "stepper": true,
      "global_key": true,
      "visible_when": {"display_mode": "leaderboard"}
    }
  ],
  "min_rows": 1,
  "min_cols": 10
}
