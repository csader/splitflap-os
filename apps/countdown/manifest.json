{
  "id": "countdown",
  "name": "Countdown",
  "icon": "⏳",
  "description": "Timer to event",
  "type": "functional",
  "refresh_interval": 1,
  "loop_delay": 1,
  "category": "time",
  "trigger_interval": 60,
  "trigger_display_seconds": 30,
  "trigger_cooldown": 86400,
  "trigger_conditions": [
    {
      "key": "milestone",
      "label": "Fire when",
      "type": "toggle",
      "default": "1d",
      "options": [
        {"value": "30d", "label": "30 days left"},
        {"value": "7d",  "label": "7 days left"},
        {"value": "1d",  "label": "1 day left"},
        {"value": "1h",  "label": "1 hour left"},
        {"value": "0",   "label": "Event arrives"}
      ]
    }
  ],
  "settings": [
    {
      "key": "countdown_enabled",
      "label": "Countdown 1",
      "type": "toggle",
      "default": "on",
      "global_key": true,
      "options": [
        {
          "value": "off",
          "label": "Off"
        },
        {
          "value": "on",
          "label": "On"
        }
      ]
    },
    {
      "key": "countdown_event",
      "label": "Countdown 1 Name (up to sign width)",
      "type": "text",
      "default": "NEW YEAR",
      "global_key": true,
      "visible_when": {
        "countdown_enabled": "on"
      }
    },
    {
      "key": "countdown_target",
