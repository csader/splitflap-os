{
  "id": "metro",
  "name": "Metro",
  "icon": "🚇",
  "description": "MBTA arrivals",
  "type": "functional",
  "refresh_interval": 30,
  "loop_delay": 5,
  "category": "data",
  "trigger_interval": 60,
  "trigger_display_seconds": 20,
  "trigger_cooldown": 300,
  "trigger_conditions": [
    {
      "key": "minutes",
      "label": "Fire when next train is within",
      "type": "number",
      "default": "5",
      "min": "1",
      "max": "15",
      "step": "1"
    },
    {
      "key": "direction",
      "label": "Direction",
      "type": "toggle",
      "default": "either",
      "options": [
        {"value": "either", "label": "Either"},
        {"value": "0",      "label": "Direction 0"},
        {"value": "1",      "label": "Direction 1"}
      ]
    }
  ],
  "settings": [
    {
      "key": "mbta_stop",
      "label": "Stop ID (e.g. place-NSTAT)",
      "type": "text",
      "default": "place-NSTAT",
      "global_key": true
    },
    {
      "key": "mbta_route",
      "label": "Route (e.g. Orange)",
      "type": "text",
      "default": "Orange",
      "global_key": true
    },
    {
      "key": "loop_delay",
      "label": "Delay Between Pages (seconds)",
      "type": "number",
      "default": "5",
      "min": "2",
      "max": "30",
      "step": "1",
      "stepper": true
    }
  ],
  "min_rows": 1,
  "min_cols": 10
}
