{
  "id": "stocks",
  "name": "Stocks",
  "icon": "📈",
  "description": "Live prices",
  "type": "functional",
  "refresh_interval": 60,
  "loop_delay": 5,
  "trigger_interval": 120,
  "trigger_display_seconds": 30,
  "trigger_cooldown": 600,
  "trigger_conditions": [
    {
      "key": "threshold",
      "label": "Fire when any ticker moves more than",
      "type": "number",
      "default": "3",
      "min": "1",
      "max": "50",
      "step": "1"
    },
    {
      "key": "direction",
      "label": "Direction",
      "type": "toggle",
      "default": "either",
      "options": [
        {"value": "either", "label": "Either"},
        {"value": "up", "label": "Up only"},
        {"value": "down", "label": "Down only"}
      ]
    }
  ],
  "settings": [
    {
      "key": "stocks_list",
      "label": "Stock Tickers",
      "type": "search_chips",
      "searchUrl": "/stocks_search",
      "resultKey": "tickers",
      "global_key": true
    },
    {
      "key": "loop_delay",
      "label": "Delay Between Pages (seconds)",
      "type": "number",
      "default": "5",
      "min": "2",
      "max": "30",
      "step": "1",
      "stepper": true
    }
  ],
  "category": "finance",
  "min_rows": 1,
  "min_cols": 8
}
