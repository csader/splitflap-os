{
  "id": "weather",
  "name": "Weather",
  "icon": "🌤️",
  "description": "Current conditions",
  "type": "functional",
  "refresh_interval": 300,
  "loop_delay": 5,
  "category": "data",
  "settings": [
    {
      "key": "zip_code",
      "label": "Zip Code",
      "type": "text",
      "default": "02118",
      "global_key": true
    },
    {
      "key": "weather_api_key",
      "label": "OpenWeatherMap API Key",
      "type": "password",
      "global_key": true
    },
    {
      "key": "timezone",
      "label": "Timezone (override global)",
      "type": "search_chips",
      "searchUrl": "/timezones",
      "resultKey": "zones",
      "maxItems": 1,
      "global_key": true
    },
    {
      "key": "show_aqi",
      "label": "Show Air Quality Index (AQI)",
      "type": "toggle",
      "default": "yes",
      "options": [
        { "value": "yes", "label": "On" },
        { "value": "no", "label": "Off" }
      ]
    },
    {
      "key": "show_pollen",
      "label": "Show Pollen / Allergy Index",
      "type": "toggle",
      "default": "yes",
      "options": [
        { "value": "yes", "label": "On" },
        { "value": "no", "label": "Off" }
      ]
    }
  ],
  "min_rows": 1,
  "min_cols": 8
}